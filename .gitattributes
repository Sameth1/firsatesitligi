# Normalize line endings — LF in the repo, LF on checkout for every OS.
# Overrides each developer's core.autocrlf so Windows clones stop showing
# phantom "modified" files caused by CRLF/LF mismatch.
* text=auto eol=lf

# Windows-only scripts must stay CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary assets — exclude from line-ending conversion
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.webp  binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.pdf   binary
