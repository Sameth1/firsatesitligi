# Bulk insert scripts (insert_programs.js / insert_programs.py) read these from the environment.
# Do not commit real secrets. Repo root .env.local is gitignored — you can set them there and:
#   PowerShell:  Get-Content .env.local | ForEach-Object { if ($_ -match '^([^#=]+)=(.*)$') { Set-Item "env:$($matches[1])" $matches[2].Trim('"') } }; node scripts/insert_programs.js
#   Or export SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY in your shell before running.
#
# If this key was ever committed: Supabase Dashboard → Project Settings → API →
# "service_role" secret → Regenerate, then update your local env and any Vercel/n8n/Edge secrets.

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Opsiyonel: Plausible Analytics (domain, örn. firsatesitligi.com)
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=firsatesitligi.com
